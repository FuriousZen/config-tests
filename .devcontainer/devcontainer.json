{
  "name": "fullstack",
  // Multi-container setup: app + postgres (see docker-compose.yml).
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  // Layer Node + Python toolchains onto the base image via features.
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/node:1": { "version": "22" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/va-h/devcontainers-features/uv:1": {}
  },

  // Experiment harness bootstrap: install the opencode CLI, provision the NIM
  // credential (from $NVIDIA_API_KEY -> opencode auth.json, no /connect needed),
  // install the react-app fixture deps, then install the two MCP servers.
  "postCreateCommand": "corepack enable; npm install -g opencode-ai; bash harness/setup_auth.sh; (cd fixtures/react-app && npm install); python3 harness/setup_mcps.py || true",

  // App dev ports + postgres.
  "forwardPorts": [3000, 5173, 8000, 5432],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },

  "remoteUser": "vscode"
}
