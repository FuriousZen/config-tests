# Copy to .devcontainer/.env and fill in (this file is committed; .env is NOT).
# Docker Compose auto-loads .devcontainer/.env and interpolates ${NVIDIA_API_KEY}
# in docker-compose.yml. harness/setup_auth.sh then writes opencode's auth.json
# from it at container build — so opencode is connected to NIM with no /connect.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx